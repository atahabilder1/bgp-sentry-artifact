# =============================================================================
# BGP-Sentry — Configuration
# =============================================================================
# Datasets: 904_afrinic_transit_mh, 2030_arin_transit,
#           3152_lacnic_afrinic_transit, 5008_lacnic_5plus_mh
#
# Usage:
#   ./target/release/bgp-sentry --dataset 904_afrinic_transit_mh

# ── Simulation ──
SIM_DURATION=43200
WARMUP_DURATION=0
SIMULATION_SPEED_MULTIPLIER=20
USE_ASYNC=true

# ── P2P Relay Filter ──
# Max P2P overlay relay hops to accept. 0 = BGP-observed only (first-hand),
# 1 = also accept 1 P2P relay from RPKI neighbor.
MAX_P2P_RELAY_HOPS=0

# ── Consensus Voting ──
# How far to reach for voters. Default: MAX_OBSERVATION_RECORDING_HOPS + 1.
# Uncomment to override:
# CONSENSUS_VOTING_HOPS=2
CONSENSUS_MIN_SIGNATURES=3
CONSENSUS_CAP_SIGNATURES=3
# Voter selection: "origin_neighbors" (ask origin's RPKI neighbors) or
# "proposer_path" (ask AS-path peers of proposer, default).
VOTER_SELECTION_MODE=origin_neighbors

# ── Voting Observation Window ──
# Voter considers observations from the last N seconds (default: 300 = 5 min).
VOTING_OBSERVATION_WINDOW=300

# ── P2P Network ──
P2P_REGULAR_TIMEOUT=30
P2P_ATTACK_TIMEOUT=60

# ── Deduplication ──
RPKI_DEDUP_WINDOW=15

# ── Attack Detection ──
FLAP_WINDOW_SECONDS=60
FLAP_THRESHOLD=3
FLAP_DEDUP_SECONDS=30

# ── Attack Detection ──
ATTACK_DETECTION_ENABLED=true

# ── Transaction Batching ──
BATCH_TIMEOUT=0.2
